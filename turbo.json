{
	"$schema": "https://turbo.build/schema.json",
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [".next/**", "!.next/cache/**", "dist/**"]
		},
		"typecheck": {
			"dependsOn": ["^build"],
			"inputs": ["**/*.ts", "**/*.tsx", "tsconfig.json"]
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
